rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidForensicCase(data) {
      // Simplified validation for debugging: ensure required fields exist and types match
      return data.keys().hasAll(['location', 'time', 'crimeType', 'status', 'date', 'confidence', 'integrityScore', 'riskLevel', 'createdBy', 'createdAt']) &&
             data.location is string &&
             data.time is string &&
             data.crimeType is string &&
             data.status in ['Real', 'Tampered'] &&
             data.date is string &&
             data.riskLevel in ['Low', 'Medium', 'High'] &&
             data.createdBy == request.auth.uid &&
             data.createdAt == request.time;
    }

    // --- Collection Routes ---

    match /cases/{caseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      
      allow create: if isSignedIn() && isValidForensicCase(incoming());
      
      allow update: if isSignedIn() && isOwner(existing().createdBy) && 
                      isValidForensicCase(incoming()) &&
                      incoming().createdBy == existing().createdBy &&
                      incoming().createdAt == existing().createdAt;
      
      allow delete: if isSignedIn() && isOwner(existing().createdBy);
    }

    match /users/{userId}/profile {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
  }
}
